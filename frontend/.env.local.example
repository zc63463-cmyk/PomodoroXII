# PomodoroXII Frontend — API / platform env

# Backend origin (used by docs; browser calls use Next.js `/api/*` rewrite)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# REST paths in code use `/api/v1` (see src/lib/platform.ts API_V1_PREFIX).
# next.config.ts rewrites `/api/:path*` → ${NEXT_PUBLIC_API_BASE}/api/:path*

# Local-only shortcut for reviewing the Quick Notes UI without backend auth.
# Production builds ignore this unless explicitly set.
# NEXT_PUBLIC_QUICK_NOTES_PREVIEW=1
